# Deployment flavor. false or absent -> Community (self-hosted). true -> Zelvem Hosted.
ZELVEM_HOSTED=false

# Stripe secret key (Hosted only). Absent -> billing does not initialize.
STRIPE_SECRET_KEY=

# Postgres connection string used by Prisma (@zelvem/database).
DATABASE_URL=postgresql://zelvem:zelvem@localhost:5432/zelvem

# Redis connection string, shared by BullMQ queues and cache.
REDIS_URL=redis://localhost:6379

# HMAC secret for signing JWTs (@zelvem/auth). Minimum 32 characters.
JWT_SECRET=

# HTTP port for the API (optional, defaults to 3001).
PORT=3001

# Base URL of the API as seen from the browser (apps/web).
NEXT_PUBLIC_API_URL=http://localhost:3001

# Base URL for the local HuggingFace TEI instance (bge-m3 embeddings).
# Internal service-to-service only — never exposed externally.
TEI_BASE_URL=http://tei:8080
