# =============================================================================
# pnpm Security Configuration
# =============================================================================
# This configuration hardens the project against supply-chain attacks
# and ensures reproducible builds.
# =============================================================================

# SECURITY: Disable automatic execution of lifecycle scripts from dependencies
# This prevents malicious packages from running arbitrary code during install
# To run scripts when needed: pnpm install --ignore-scripts=false
ignore-scripts=true

# SECURITY: Use exact versions when adding new dependencies
# Prevents silent updates via ^ or ~ ranges
save-exact=true

# SECURITY: Strict peer dependencies - warn on mismatches
strict-peer-dependencies=false

# CI/Reproducibility: Fail if lockfile is out of date
# Set to true in CI environments, use false during initial setup
# Use --frozen-lockfile flag in CI pipelines
frozen-lockfile=false

# Compatibility: Hoist packages for tools that expect flat node_modules
# NestJS, ESLint, Prettier and other tools may need this
shamefully-hoist=true

# Explicit registry to prevent registry confusion attacks
registry=https://registry.npmjs.org/

# Public hoist pattern for type definitions and tooling
public-hoist-pattern[]=*types*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*

